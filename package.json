{
  "name": "code-excerpter",
  "version": "0.0.1",
  "description": "A line-based tool for extracting and injecting code excerpts into documentation.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "code-excerpter": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "check:spelling": "npx cspell --no-progress -c .cspell.yml *.md 'docs/**/*.md'",
    "check": "npm run check:spelling && npm run lint",
    "dev": "tsx src/cli.ts",
    "fix": "npm run lint:fix",
    "lint:fix": "biome check . --write",
    "lint": "biome check .",
    "prepare": "tsup",
    "test:watch": "vitest",
    "test:base": "vitest run",
    "test": "npm run check && npm run test:base",
    "update:packages": "npx npm-check-updates -u"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chalin/code-excerpter.git"
  },
  "author": "Patrice Chalin",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "cspell": "^9.7.0",
    "npm-check-updates": "^19.6.6",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.2",
    "vitest": "^3.0.0"
  }
}
