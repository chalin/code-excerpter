{
  "name": "code-excerpter",
  "version": "0.0.1",
  "description": "A line-based tool for extracting and injecting code excerpts into documentation.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "code-excerpter": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "__check:format": "npx prettier --ignore-unknown",
    "_build": "tsup && tsc --emitDeclarationOnly",
    "_diff:fail": "git diff --name-only --exit-code || exit 1",
    "_fix:format:diff": "prettier --write --ignore-unknown --ignore-path .prettierignore",
    "_list:diff:all": "(npm run -s _list:diff -- HEAD; git ls-files --others --exclude-standard) | sort -u",
    "_list:diff": "git diff --name-only --diff-filter=AMR",
    "build": "npm run _build",
    "check:format": "npm run __check:format -- --check .",
    "check:spelling": "npx cspell --no-progress -c .cspell.yml *.md 'docs/**/*.md'",
    "check:types": "tsc --noEmit",
    "check": "npm run check:format && npm run lint && npm run check:types && npm run check:spelling",
    "dev": "tsx src/cli.ts",
    "fix:format:diff": "npm run _fix:format:diff -- $(npm -s run _list:diff:all)",
    "fix:format": "npm run check:format -- --write",
    "fix:lint": "biome check . --write",
    "fix": "npm run fix:lint && npm run fix:format",
    "lint": "biome check .",
    "postbuild": "node scripts/verify-dist.mjs",
    "prepare": "npm run build",
    "test:base": "vitest run",
    "test:watch": "vitest",
    "test": "npm run check && npm run test:base",
    "update:packages": "npx npm-check-updates -u"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chalin/code-excerpter.git"
  },
  "author": "Patrice Chalin",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "cspell": "^10.0.0",
    "npm-check-updates": "^20.0.1",
    "prettier": "^3.6.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
