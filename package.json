{
  "name": "code-excerpter",
  "version": "0.1.0",
  "description": "A line-based tool for extracting and injecting code excerpts into documentation.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "code-excerpter": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "__check:format": "prettier --ignore-unknown",
    "_build": "tsup && tsc --emitDeclarationOnly",
    "_diff:fail": "git diff --name-only --exit-code",
    "_fix:markdown:lint": "npm run check:markdown -- --fix",
    "_fix:trailing-spaces": "find . -name '*.md' -exec perl -i -pe 's/[ \t]+$//g' {} +",
    "_list:diff-never-empty": "git diff --name-only --diff-filter=AMR HEAD | awk 'NF{print;c++} END{if(c==0)print \"README.md\"}'",
    "_list:diff:all": "(npm run -s _list:diff-never-empty; git ls-files --others --exclude-standard) | sort -u",
    "build": "npm run _build",
    "check:format": "npm run __check:format -- --check .",
    "check:markdown": "markdownlint-cli2",
    "check:spelling": "cspell --no-progress -c .cspell.yml *.md 'docs/**/*.md'",
    "check:types": "tsc --noEmit",
    "check": "npm run seq -- check:format lint check:types check:markdown check:spelling",
    "clean-tmp-test-dir": "rm -Rf tmp/ce-test-* || true",
    "dev": "tsx src/cli.ts",
    "fix:format:diff": "npm run __check:format -- --write $(npm -s run _list:diff:all)",
    "fix:format": "npm run check:format -- --write",
    "fix:lint": "eslint . --fix",
    "fix:markdown": "npm run seq -- _fix:markdown:lint _fix:trailing-spaces",
    "fix": "npm run seq -- fix:lint fix:markdown fix:format",
    "lint": "eslint .",
    "postbuild": "node scripts/verify-dist.mjs",
    "prepare": "npm run build",
    "pretest:base": "npm run build",
    "pretest:watch": "npm run build",
    "seq": "bash -c 'for cmd in \"$@\"; do npm run $cmd || exit 1; done' - ",
    "test:base": "KEEP_TEST_TMP=${KEEP_TEST_TMP:-0} vitest run",
    "test:watch": "vitest",
    "test": "npm run check && npm run test:base",
    "update:packages": "npm-check-updates -u"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chalin/code-excerpter.git"
  },
  "author": "Patrice Chalin",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "cspell": "^10.0.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "markdownlint-cli2": "^0.22.0",
    "npm-check-updates": "^20.0.1",
    "prettier": "^3.8.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4",
    "yaml": "^2.8.3"
  }
}
